# ============================================
# ZEUS CRM PRO - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Server
NODE_ENV=production
PORT=3000
API_BASE_URL=https://api.zeusgetquote.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=zeus-crm-9d5ef
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@zeus-crm-9d5ef.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_DATABASE_URL=https://zeus-crm-9d5ef.firebaseio.com

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Admin Access
ADMIN_KEY=zeus2026admin

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Zeus CRM <noreply@zeusgetquote.com>

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI (AI Features)
OPENAI_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=https://zeusgetquote.com

# Logging
LOG_LEVEL=info
